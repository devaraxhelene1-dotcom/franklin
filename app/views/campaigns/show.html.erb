<div class="campaign-show">
  <div class="container">

    <div class="campaign-show-header">
      <%= link_to "← Mes campagnes", campaigns_path, class: "back-link" %>
      <div class="campaign-show-title-row">
        <h1><%= @campaign.title %></h1>
        <span class="step-status-badge <%= @campaign.status %>">
          <%= case @campaign.status
              when "draft" then "Brouillon"
              when "active" then "Active"
              when "completed" then "Terminée"
              end %>
        </span>
      </div>
      <p class="campaign-show-date">Créée le <%= @campaign.created_at.strftime("%d/%m/%Y") %></p>
    </div>

    <div class="campaign-cards-grid">

      <div class="campaign-card">
        <div class="campaign-card-header">
          <span class="campaign-card-icon">🎯</span>
          <h3>ICP</h3>
        </div>
        <div class="campaign-card-body">
          <% if @campaign.icp.present? %>
            <%= @campaign.icp %>
          <% else %>
            <span class="empty-field">Non défini</span>
          <% end %>
        </div>
      </div>

      <div class="campaign-card">
        <div class="campaign-card-header">
          <span class="campaign-card-icon">📡</span>
          <h3>Cannaux</h3>
        </div>
        <div class="campaign-card-body">
          <% if @campaign.channels.present? %>
            <%= @campaign.channels %>
          <% else %>
            <span class="empty-field">Non défini</span>
          <% end %>
        </div>
      </div>

      <div class="campaign-card">
        <div class="campaign-card-header">
          <span class="campaign-card-icon">💡</span>
          <h3>Angles</h3>
        </div>
        <div class="campaign-card-body">
          <% if @campaign.angles.present? %>
            <%= @campaign.angles %>
          <% else %>
            <span class="empty-field">Non défini</span>
          <% end %>
        </div>
      </div>

      <div class="campaign-card">
        <div class="campaign-card-header">
          <span class="campaign-card-icon">📄</span>
          <h3>Documentation</h3>
        </div>
        <div class="campaign-card-body">
          <% if @campaign.doc_content.present? %>
            <%= simple_format @campaign.doc_content %>
          <% else %>
            <span class="empty-field">Aucune documentation</span>
          <% end %>
        </div>
      </div>

    </div>

    <div class="campaign-steps-section">
      <h2>Étapes de la campagne</h2>
      <% if @campaign.steps.any? %>
        <div class="steps-list">
          <% @campaign.steps.order(:day).each do |step| %>
            <%= link_to campaign_step_path(@campaign, step), class: "step-item #{step.status}", style: "text-decoration: none;" do %>
              <div class="step-day">Jour <%= step.day %></div>
              <div class="step-content">
                <% if step.generated_content.present? %>
                  <%= step.generated_content %>
                <% else %>
                  <span class="empty-field">Contenu non généré</span>
                <% end %>
              </div>
              <span class="step-status-badge <%= step.status %>">
                <%= step.status == "done" ? "Fait" : "En attente" %>
              </span>
            <% end %>
          <% end %>
        </div>
      <% else %>
        <div class="steps-empty">
          <p>Aucune étape pour cette campagne.</p>
        </div>
      <% end %>
    </div>

  </div>
</div>
