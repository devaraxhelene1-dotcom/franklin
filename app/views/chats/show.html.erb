<%= turbo_stream_from @chat %>

<div class="chat-container <%= 'has-messages' if @chat.messages.any? %>" data-controller="chat">
  <div class="chat-title mt-5">
  <h2>
    <span class="typewriter-black" data-chat-target="typewriterBlack"></span>
    <span class="typewriter-green" data-chat-target="typewriterGreen"></span>
    <span class="typewriter-cursor">|</span>
  </h2>
</div>

  <% if @chat.campaign&.status == "active" %>
    <div class="campaign-created-banner">
      <div class="campaign-banner-left">
        <span class="campaign-banner-icon">🎯</span>
        <div>
          <p class="campaign-banner-label">Campagne créée</p>
          <p class="campaign-banner-title"><%= @chat.campaign.title %></p>
        </div>
      </div>
      <%= link_to campaign_path(@chat.campaign), class: "btn btn-campaign-link" do %>
        Voir ma campagne <span>→</span>
      <% end %>
    </div>
  <% end %>

  <div class="chat-messages" id="chat_messages" data-chat-target="messages">
    <% @chat.messages.order(:created_at).each do |message| %>
      <%= render partial: "messages/message", locals: { message: message } %>
    <% end %>

    <div class="message message-bot d-none" id="loading-indicator" data-chat-target="loading">
      <div class="message-content bubble-bot">Franklin est en train d'écrire...</div>
    </div>
  </div>

  <div class="chat-loading-backdrop d-none" id="validation-loading" data-chat-target="validationLoading">
    <%= image_tag "Logo_Franklin.png", class: "chat-loading-logo", alt: "Chargement" %>
  </div>

  <div class="chat-input">
    <%= form_with model: [@chat, Message.new], url: chat_messages_path(@chat), id: "chat_input_form", multipart: true,
        data: { action: "submit->chat#submit" } do |f| %>
      <div class="input-wrapper">
        <div class="file-preview d-none" data-chat-target="filePreview">
          <div class="file-chip">
            <i class="fa-solid fa-file-lines"></i>
            <span data-chat-target="fileName"></span>
            <button type="button" class="file-remove-btn" data-action="click->chat#removeFile">&times;</button>
          </div>
        </div>
        <div class="input-row">
          <label class="file-upload-btn" title="Joindre un fichier">
            <i class="fa-solid fa-paperclip"></i>
            <%= f.file_field :file, style: "display: none;", data: { action: "change->chat#fileChange", chat_target: "fileInput" } %>
          </label>
          <%= f.text_area :content, placeholder: "Décrivez votre projet...", rows: 1, data: { action: "input->chat#autoResize keydown->chat#submitOnEnter", chat_target: "content" } %>
          <%= f.submit "➤", data: { chat_target: "submit" } %>
        </div>
      </div>
    <% end %>
  </div>
</div>
