<% last_bot_message = @chat.messages.where(role: "assistant").last %>
<% awaiting_validation = last_bot_message&.content&.include?("[VALIDATE]") && @chat.campaign.nil? %>

<div class="chat-container" data-controller="chat">
  <div class="chat-title mt-5">
    <h2>Discutez avec <span>Franklin</span></h2>
  </div>

  <% if @chat.campaign.present? %>
    <div class="campaign-created-banner">
      <div class="campaign-banner-left">
        <span class="campaign-banner-icon">🎯</span>
        <div>
          <p class="campaign-banner-label">Campagne créée</p>
          <p class="campaign-banner-title"><%= @chat.campaign.title %></p>
        </div>
      </div>
      <%= link_to campaign_path(@chat.campaign), class: "btn btn-campaign-link" do %>
        Voir ma campagne <span>→</span>
      <% end %>
    </div>
  <% end %>

  <div class="chat-messages" data-chat-target="messages">
    <% @chat.messages.order(:created_at).each do |message| %>
      <div class="message <%= message.role == 'user' ? 'message-user' : 'message-bot' %>">
        <div class="message-content <%= message.role == 'user' ? 'bubble-user' : 'bubble-bot' %>">
          <% display = message.content.gsub("[VALIDATE]", "").gsub(/\n\n--- Document (PDF )?fourni par l'utilisateur ---\n.*\z/m, "").strip %>
          <% display = "" if display == "J'ai joint une image." && message.file.attached? %>
          <%= display if display.present? %>
          <% if message.file.attached? %>
            <% if message.file.content_type&.start_with?("image/") %>
              <%= image_tag rails_blob_path(message.file, disposition: "inline"), class: "chat-image mt-2" %>
            <% else %>
              <div class="file-badge mt-2">
                <i class="fa-solid fa-file-lines me-1"></i><%= message.file.filename %>
              </div>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>

    <div class="message message-bot d-none" data-chat-target="loading">
      <div class="message-content bubble-bot">Franklin est en train d'écrire...</div>
    </div>
  </div>

  <% if awaiting_validation %>
    <div class="validate-banner">
      <p class="validate-banner-text">Prêt à lancer la campagne ?</p>
      <%= form_with url: chat_messages_path(@chat), data: { action: "submit->chat#submit" } do |f| %>
        <input type="hidden" name="message[content]" value="Je valide la stratégie proposée.">
        <%= f.submit "✓ Valider la stratégie", class: "btn btn-validate", data: { chat_target: "submit" } %>
      <% end %>
    </div>
  <% end %>

  <div class="chat-input">
    <%= form_with model: [@chat, Message.new], url: chat_messages_path(@chat), multipart: true,
        data: { action: "submit->chat#submit" } do |f| %>
      <div class="input-wrapper">
        <label class="file-upload-btn" title="Joindre un fichier">
          <i class="fa-solid fa-paperclip"></i>
          <%= f.file_field :file, style: "display: none;", data: { action: "change->chat#fileChange", chat_target: "fileInput" } %>
        </label>
        <%= f.text_area :content, placeholder: "Envoyer un message...", rows: 1 %>
        <%= f.submit "➤", data: { chat_target: "submit" } %>
      </div>
      <div class="file-preview d-none" data-chat-target="filePreview">
        <i class="fa-solid fa-paperclip me-1"></i>
        <span data-chat-target="fileName"></span>
        <button type="button" class="file-remove-btn" data-action="click->chat#removeFile">&times;</button>
      </div>
    <% end %>
  </div>
</div>
