<div class="card carte shadow-sm mx-auto mt-5" style="max-width:420px">
  <div class="card-body p-4">
    <h2 class="fw-bold mb-1">Modifier votre mot de passe</h2>
    <p class="text-muted mb-4">Choisissez un nouveau mot de passe</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :reset_password_token, as: :hidden %>
      <%= f.full_error :reset_password_token %>

      <%= f.input :password,
                  label: "Nouveau mot de passe",
                  required: true,
                  autofocus: true,
                  hint: ("#{@minimum_password_length} caractères minimum" if @minimum_password_length),
                  input_html: { autocomplete: "new-password", class: "form-control" } %>
      <%= f.input :password_confirmation,
                  label: "Confirmer votre nouveau mot de passe",
                  required: true,
                  input_html: { autocomplete: "new-password", class: "form-control" } %>

      <%= f.button :submit, "Modifier mon mot de passe", class: "btn btn-connect w-100 mt-2" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
