<div class="card carte shadow-sm mx-auto mt-5" style="max-width:420px">
  <div class="card-body p-4">
    <h2 class="fw-bold mb-1">Mot de passe oublié ?</h2>
    <p class="text-muted mb-4">Entrez votre e-mail pour recevoir les instructions</p>

    <%= simple_form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
      <%= f.error_notification %>

      <%= f.input :email,
                  required: true,
                  autofocus: true,
                  label: "Adresse e-mail",
                  input_html: { autocomplete: "email", class: "form-control" } %>

      <%= f.button :submit, "Envoyer les instructions de réinitialisation", class: "btn btn-connexion w-100 mt-2" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
