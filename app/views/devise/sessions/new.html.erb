<div class="auth-page">
  <div class="auth-card">
    <div class="auth-card__logo">
      <%= link_to root_path do %>
        <%= image_tag "Logo_Franklin.png", style: "height: 44px; width: auto;" %>
      <% end %>
    </div>

    <h2 class="auth-card__title">Bon retour</h2>
    <p class="auth-card__sub">Connectez-vous à votre compte</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.input :email,
            required: false,
            autofocus: true,
            label: "Adresse e-mail",
            input_html: { autocomplete: "email", class: "auth-input" },
            wrapper_html: { class: "auth-field" } %>
      <%= f.input :password,
            required: false,
            label: "Mot de passe",
            input_html: { autocomplete: "current-password", class: "auth-input" },
            wrapper_html: { class: "auth-field" } %>
      <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi", wrapper_html: { class: "auth-remember" } if devise_mapping.rememberable? %>
      <%= f.button :submit, "Se connecter →", class: "lp-btn lp-btn--primary auth-submit" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
