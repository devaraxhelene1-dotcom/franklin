<div class="card carte shadow-sm mx-auto mt-5" style="max-width:420px">
  <div class="card-body p-4">
    <h2 class="fw-bold mb-1">Bon retour 👋</h2>
    <p class="text-muted mb-4">Connectez-vous à votre compte</p>

    <%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
      <%= f.input :email, required: false, autofocus: true, label: "Adresse e-mail", input_html: { autocomplete: "email", class: "form-control" } %>
      <%= f.input :password, required: false, label: "Mot de passe", input_html: { autocomplete: "current-password", class: "form-control" } %>
      <%= f.input :remember_me, as: :boolean, label: "Se souvenir de moi" if devise_mapping.rememberable? %>
      <%= f.button :submit, "Se connecter", class: "btn btn-registration w-100 mt-2" %>
    <% end %>

    <%= render "devise/shared/links" %>
  </div>
</div>
