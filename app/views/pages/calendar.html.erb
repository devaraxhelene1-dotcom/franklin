<% campaign_ids = @active_campaigns.map(&:id) %>

<div class="calendar-page" data-controller="calendar-filter">
  <div class="calendar-header">
    <div>
      <h1 class="calendar-title">Calendrier</h1>
      <p class="calendar-subtitle">Vue d'ensemble — Mars 2026</p>
    </div>
    <select class="calendar-filter-select"
            data-calendar-filter-target="select"
            data-action="change->calendar-filter#filter">
      <option value="all">Toutes les campagnes</option>
      <% @active_campaigns.each do |campaign| %>
        <option value="<%= campaign.id %>"><%= campaign.title %></option>
      <% end %>
    </select>
  </div>

  <div class="calendar-grid" data-calendar-filter-target="grid">
    <% %w[Lun Mar Mer Jeu Ven Sam Dim].each do |day_name| %>
      <div class="calendar-day-header"><%= day_name %></div>
    <% end %>

    <% (@start_date..@end_date).each do |date| %>
      <% entries = @calendar_steps[date] %>
      <% past = date < Date.current %>
      <div class="calendar-cell <%= 'today' if date == Date.current %> <%= 'past' if past %>">
        <div class="calendar-date-row">
          <span class="calendar-date"><%= date.day %></span>
          <% if entries.any? %>
            <span class="calendar-count"><%= entries.size %></span>
          <% end %>
        </div>
        <div class="calendar-badges">
          <% entries.first(3).each do |entry| %>
            <div class="calendar-badge-wrapper">
              <%= link_to campaign_path(entry[:campaign]),
                    class: "calendar-badge #{campaign_color_class(entry[:campaign].id, campaign_ids)} #{'done' if entry[:step].status == 'done'}",
                    data: { campaign_id: entry[:campaign].id } do %>
                <%= "#{entry[:step_index]}/#{entry[:total_steps]} - #{truncate(entry[:campaign].title, length: 10)}" %>
              <% end %>
              <div class="calendar-popover">
                <div class="popover-step-num"><%= "Step #{entry[:step_index]}/#{entry[:total_steps]}" %></div>
                <div class="popover-campaign"><%= entry[:campaign].title %></div>
                <div class="popover-channel"><%= entry[:channel] %></div>
              </div>
            </div>
          <% end %>
          <% if entries.size > 3 %>
            <span class="calendar-more">+<%= entries.size - 3 %> autre<%= "s" if entries.size - 3 > 1 %></span>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
