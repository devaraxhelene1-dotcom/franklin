<div class="sidebar" id="sidebar" data-controller="sidebar" data-sidebar-target="panel">
  <div class="sidebar-header">
    <div class="sidebar-brand">
      <%= link_to "#" do %>
        <%= image_tag "Logo_Franklin.png", class: "sidebar-logo" %>
      <% end %>
    </div>
    <button class="sidebar-toggle" data-action="click->sidebar#toggle">
      <i class="fa-solid fa-xmark sidebar-close-icon"></i>
      <i class="fa-solid fa-bars sidebar-open-icon"></i>
    </button>
  </div>

    <li class="sidebar-item new-chath">
  <%= button_to chats_path, method: :post, class: "sidebar-link" do %>
    <i class="fa-solid fa-plus icon-new-chat"></i>
    <span>Nouveau chat</span>
  <% end %>
    </li>


  <ul class="sidebar-nav">
    <li class="sidebar-item <%= 'active' if current_page?(root_path) %>">
      <%= link_to root_path, class: "sidebar-link" do %>
        <i class="fa-solid fa-chart-line icons"></i>
        <span>Dashboard</span>
      <% end %>
    </li>

    <li class="sidebar-item <%= 'active' if current_page?(campaigns_path) %>" data-controller="dropdown">
      <%= link_to campaigns_path, class: "sidebar-link" do %>
      <i class="fa-solid fa-table-columns"></i>
      <span>Mes campagnes</span>
      <% end %>

      <% if @campaigns.present? %>
        <button class="sidebar-chevron-btn" data-action="click->dropdown#toggle">
          <i class="fa-solid fa-chevron-down sidebar-chevron" data-dropdown-target="chevron"></i>
        </button>
        <ul class="sidebar-submenu" data-dropdown-target="menu" <%= 'hidden' unless controller_name == 'campaigns' && action_name == 'show' %>>
          <% @campaigns.each do |campaign| %>
            <li class="sidebar-submenu-item <%= 'active' if current_page?(campaign_path(campaign)) %>">
              <%= link_to campaign.title, campaign_path(campaign), class: "sidebar-submenu-link" %>
            </li>
          <% end %>
        </ul>
      <% end %>
    </li>

    <li class="sidebar-item <%= 'active' if current_page?(root_path) %>">
      <%= link_to root_path, class: "sidebar-link" do %>
        <i class="fa-solid fa-gear icons"></i>
        <span>Paramètres</span>
      <% end %>
    </li>


  </ul>

<div class="sidebar-footer">
    <% if user_signed_in? %>
      <div class="sidebar-user">
        <div class="sidebar-user-avatar">
          <%= current_user.username&.first&.upcase %>
        </div>
        <span class="sidebar-user-name"><%= current_user.username&.capitalize %></span>
      </div>
      <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "sidebar-link sidebar-logout" do %>
        <i class="fa-solid fa-right-from-bracket"></i>
        <span>Se déconnecter</span>
      <% end %>
    <% else %>
      <%= link_to "Se connecter", new_user_session_path, class: "btn btn-sidebar-login" %>
      <%= link_to "S'inscrire", new_user_registration_path, class: "btn btn-sidebar-signup" %>
    <% end %>
  </div>
</div>
