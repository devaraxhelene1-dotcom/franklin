  "Email"           => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>',
  "Twitter / X"     => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.736l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>',
  "Instagram"       => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>',
  "TikTok"          => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 0 1-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 0 1-2.88 2.5 2.89 2.89 0 0 1-2.89-2.89 2.89 2.89 0 0 1 2.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 0 0-.79-.05 6.34 6.34 0 0 0-6.34 6.34 6.34 6.34 0 0 0 6.34 6.34 6.34 6.34 0 0 0 6.33-6.34V8.69a8.16 8.16 0 0 0 4.78 1.52V6.75a4.85 4.85 0 0 1-1.01-.06z"/></svg>',
  "Facebook"        => '<svg viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>',
  "Blog / Article"  => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>',
  "Forum / Reddit"  => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>',
  "Slack / Discord" => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.5 10c-.83 0-1.5-.67-1.5-1.5v-5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5zM20.5 10H19V8.5c0-.83.67-1.5 1.5-1.5s1.5.67 1.5 1.5-.67 1.5-1.5 1.5zM9.5 14c.83 0 1.5.67 1.5 1.5v5c0 .83-.67 1.5-1.5 1.5S8 21.33 8 20.5v-5c0-.83.67-1.5 1.5-1.5zM3.5 14H5v1.5c0 .83-.67 1.5-1.5 1.5S2 16.33 2 15.5 2.67 14 3.5 14zM14 14.5c0-.83.67-1.5 1.5-1.5h5c.83 0 1.5.67 1.5 1.5s-.67 1.5-1.5 1.5h-5c-.83 0-1.5-.67-1.5-1.5zM15.5 19H14v1.5c0 .83.67 1.5 1.5 1.5s1.5-.67 1.5-1.5-.67-1.5-1.5-1.5zM10 9.5C10 8.67 9.33 8 8.5 8h-5C2.67 8 2 8.67 2 9.5S2.67 11 3.5 11h5c.83 0 1.5-.67 1.5-1.5zM8.5 5H10V3.5C10 2.67 9.33 2 8.5 2S7 2.67 7 3.5 7.67 5 8.5 5z"/></svg>',
  "Autre"           => '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="1"/><circle cx="19" cy="12" r="1"/><circle cx="5" cy="12" r="1"/></svg>'
} %>

<% display_name = current_user.username.presence || current_user.email.split("@").first %>
<% display_initial = display_name[0].upcase %>
<% channel_colors = {
  "LinkedIn"        => "#0A66C2",
  "Twitter / X"     => "#1a1a18",
  "Email"           => "#6366f1",
  "Instagram"       => "#E1306C",
  "TikTok"          => "#1a1a18",
  "Facebook"        => "#1877F2",
  "Blog / Article"  => "#7c3aed",
  "Forum / Reddit"  => "#FF4500",
  "Slack / Discord" => "#4A154B",
  "Autre"           => "#6b7280"
} %>

<div class="step-page"
     data-controller="step-editor"
     data-step-editor-channel-limits-value='{"LinkedIn":3000,"Twitter / X":280,"Instagram":2200,"TikTok":2200,"Facebook":63206,"Email":0,"Blog / Article":0,"Forum / Reddit":0,"Slack / Discord":0,"Autre":0}'
     data-step-editor-user-name-value="<%= display_name %>"
     data-step-editor-user-initial-value="<%= display_initial %>">
  <div class="step-page-inner">

    <%# ── Sticky top bar ──────────────────────────────────────────── %>
    <%= simple_form_for [@campaign, @step] do |f| %>

    <div class="step-topbar">
      <%= link_to campaign_path(@campaign), class: "step-back" do %>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
        <%= @campaign.title %>
      <% end %>

      <div class="step-topbar-center">
        <span class="step-day-tag">Jour <%= @step.day %></span>
        <span class="step-status-pill <%= @step.status %>" data-step-editor-target="statusBadge">
          <span class="step-status-dot"></span>
          <%= @step.status == "done" ? "Fait" : "En attente" %>
        </span>
      </div>

    </div>

    <%# ── Channel nav ──────────────────────────────────────────────── %>
    <div class="step-channel-nav"
         data-step-editor-target="channelSelect"
         data-action="change->step-editor#updateChannelUI">
      <% Step::CHANNELS.each do |ch| %>
        <label class="step-channel-tab" style="--tab-color: <%= channel_colors[ch] || '#1a1a18' %>">
          <input type="radio"
                 name="step[channel]"
                 value="<%= ch %>"
                 <%= "checked" if @parsed[:channel] == ch || (@parsed[:channel].blank? && ch == Step::CHANNELS.first) %>>
          <span class="step-channel-tab-inner">
            <%= raw channel_icons.fetch(ch, channel_icons["Autre"]) %>
            <%= ch %>
          </span>
        </label>
      <% end %>
    </div>

    <%# ── Two-column: Editor + Preview ────────────────────────────── %>
    <div class="step-two-col">

      <%# Left: content editor + instructions %>
      <div class="step-editor-col">
        <div class="step-editor-box">
          <div class="step-editor-box-header">
            <span class="step-editor-box-label">Contenu à poster</span>
            <span class="step-char-count" data-step-editor-target="charCount"></span>
          </div>
          <div class="step-format-toolbar">
            <button type="button" class="step-fmt-btn" title="Gras (Ctrl+B)" data-action="mousedown->step-editor#format" data-step-editor-fmt-param="bold"><svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor"><path d="M6 4h8a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/><path d="M6 12h9a4 4 0 0 1 4 4 4 4 0 0 1-4 4H6z"/></svg></button>
            <button type="button" class="step-fmt-btn" title="Italique (Ctrl+I)" data-action="mousedown->step-editor#format" data-step-editor-fmt-param="italic"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="19" y1="4" x2="10" y2="4"/><line x1="14" y1="20" x2="5" y2="20"/><line x1="15" y1="4" x2="9" y2="20"/></svg></button>
            <button type="button" class="step-fmt-btn" title="Barré" data-action="mousedown->step-editor#format" data-step-editor-fmt-param="strike"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><path d="M17.3 12H6.7"/><path d="M10 6.3C10 5 11 4 12.5 4s2.5 1 2.5 2.3c0 .7-.3 1.3-.8 1.7"/><path d="M14 17.7c0 1.3-1 2.3-2.5 2.3S9 19 9 17.7c0-.7.3-1.3.8-1.7"/></svg></button>
            <span class="step-fmt-sep"></span>
            <button type="button" class="step-fmt-btn" title="Liste à puces" data-action="mousedown->step-editor#format" data-step-editor-fmt-param="ul"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="9" y1="6" x2="20" y2="6"/><line x1="9" y1="12" x2="20" y2="12"/><line x1="9" y1="18" x2="20" y2="18"/><circle cx="4" cy="6" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="12" r="1" fill="currentColor" stroke="none"/><circle cx="4" cy="18" r="1" fill="currentColor" stroke="none"/></svg></button>
            <button type="button" class="step-fmt-btn" title="Liste numérotée" data-action="mousedown->step-editor#format" data-step-editor-fmt-param="ol"><svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2"><line x1="10" y1="6" x2="21" y2="6"/><line x1="10" y1="12" x2="21" y2="12"/><line x1="10" y1="18" x2="21" y2="18"/><path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/></svg></button>
          </div>
          <%# Hidden input sent with form — synced from contenteditable via JS %>
          <input type="hidden" name="step[content_body]"
                 value="<%= j @parsed[:content] %>"
                 data-step-editor-target="contentBody">
          <div class="step-prose step-prose--editable"
               contenteditable="true"
               spellcheck="true"
               data-step-editor-target="contentArea"
               data-action="input->step-editor#onInput keydown->step-editor#keyFormat"
               data-placeholder="Rédigez ici le texte complet à copier-coller sur le canal…"><%= raw sanitize(@parsed[:content].to_s, tags: %w[b i strong em del s br div p ul ol li], attributes: []) %></div>
        </div>

        <div class="step-workflow-section">
          <div class="step-workflow-header">
            <span class="step-label" style="margin:0;">Instructions</span>
            <span class="step-workflow-hint">Une action par ligne</span>
          </div>
          <textarea name="step[instructions]"
                    class="step-workflow-field"
                    placeholder="Aller sur LinkedIn&#10;Créer une nouvelle publication&#10;Coller le contenu&#10;Ajouter l'image générée&#10;Publier"><%= @parsed[:instructions] %></textarea>
        </div>

        <div class="step-edit-footer">
          <div class="step-footer-status-group">
            <span class="step-footer-label">Statut</span>
            <%= f.select :status, [["En attente", "pending"], ["Fait", "done"]], {},
                class: "step-status-select",
                data: { step_editor_target: "statusSelect", action: "change->step-editor#updateStatusBadge" } %>
          </div>
          <div class="step-footer-actions">
            <%= link_to "Annuler", campaign_step_path(@campaign, @step), class: "step-btn-ghost" %>
            <%= f.submit "Enregistrer", class: "step-btn-primary", data: { disable_with: "Enregistrement…" } %>
          </div>
        </div>
      </div>

      <%# Right: live preview %>
      <div class="step-preview-col">
        <div class="step-preview-wrap">
          <div class="step-preview-header">
            <span class="step-preview-title">Aperçu</span>
            <span class="step-preview-channel-name" data-step-editor-target="previewChannelName">
              <%= @parsed[:channel].present? ? @parsed[:channel] : Step::CHANNELS.first %>
            </span>
          </div>
          <div class="step-preview-body">
            <div class="step-preview-card">
              <div class="step-preview-card-accent" data-step-editor-target="previewAccent"></div>
              <div class="step-preview-card-inner">
                <div class="step-preview-card-header">
                  <div class="step-preview-avatar" data-step-editor-target="previewAvatar"><%= display_initial %></div>
                  <div>
                    <div class="step-preview-name"><%= display_name %></div>
                    <div class="step-preview-sub" data-step-editor-target="previewSub">LinkedIn · Maintenant · 🌐</div>
                  </div>
                </div>
                <% if @step.image.attached? %>
                  <div class="step-preview-image-wrap">
                    <%= image_tag @step.image, class: "step-preview-image" %>
                  </div>
                <% end %>
                <p class="step-preview-text is-placeholder" data-step-editor-target="previewText">Votre contenu apparaîtra ici…</p>
                <div class="step-preview-actions" data-step-editor-target="previewActions">
                  <span>👍 J'aime</span><span>💬 Commenter</span><span>↗ Partager</span>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <% end %>

  </div>
</div>
